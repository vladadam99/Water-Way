<section class="ww-container ww-page">
  <div class="ww-section__head">
    <div>
      <div class="ww-kicker">Water Way Guides</div>
      <h1>{{ blog.title }}</h1>
      <p>Practical guides for saving water, improving water quality, irrigating efficiently and protecting property.</p>
    </div>
  </div>

  {% if blog.articles_count > 0 %}
    <div class="ww-grid ww-grid--3">
      {% paginate blog.articles by 12 %}
        {% for article in blog.articles %}
          <a class="ww-category-card" href="{{ article.url }}">
            <span>📘</span>
            <h3>{{ article.title }}</h3>
            <p>{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
          </a>
        {% endfor %}
      {% endpaginate %}
    </div>
  {% else %}
    <div class="ww-empty">Water Way guides will appear here soon.</div>
  {% endif %}
</section>

{% schema %}
{ "name": "Main blog", "settings": [] }
{% endschema %}
