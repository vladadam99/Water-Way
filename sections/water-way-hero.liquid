<section class="ww-hero">
  <div class="ww-container ww-hero__grid">
    <div>
      <div class="ww-kicker">{{ section.settings.kicker }}</div>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      <div class="ww-hero__actions">
        <a class="ww-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        <a class="ww-button ww-button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
    <div class="ww-card ww-hero__panel">
      <div class="ww-stat-grid">
        <div class="ww-stat"><strong>Save</strong><span>Reduce water waste with practical upgrades.</span></div>
        <div class="ww-stat"><strong>Filter</strong><span>Improve everyday water quality.</span></div>
        <div class="ww-stat"><strong>Irrigate</strong><span>Water gardens with precision.</span></div>
        <div class="ww-stat"><strong>Protect</strong><span>Detect leaks before they cause damage.</span></div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Water Way hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Water Way" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The smarter way to manage water." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Shop trusted water-saving, filtration, irrigation, cleaning and leak-protection products for your home, garden or business." },
    { "type": "text", "id": "primary_label", "label": "Primary button", "default": "Shop products" },
    { "type": "url", "id": "primary_link", "label": "Primary link", "default": "/collections/all" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button", "default": "Explore categories" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link", "default": "/collections" }
  ],
  "presets": [{ "name": "Water Way hero" }]
}
{% endschema %}
