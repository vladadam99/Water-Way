<section class="ww-hero">
  <div class="ww-container ww-hero__grid">
    <div>
      <div class="ww-kicker">{{ section.settings.kicker }}</div>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      <div class="ww-hero__actions">
        <a class="ww-button" href="/collections/all">{{ section.settings.primary_label }}</a>
        <a class="ww-button ww-button--secondary" href="/collections">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
    <div class="ww-card ww-hero__panel">
      <div class="ww-stat-grid">
        <div class="ww-stat"><strong>Save</strong><span>Reduce everyday water use.</span></div>
        <div class="ww-stat"><strong>Filter</strong><span>Improve water quality.</span></div>
        <div class="ww-stat"><strong>Irrigate</strong><span>Water gardens efficiently.</span></div>
        <div class="ww-stat"><strong>Maintain</strong><span>Keep water systems working well.</span></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Water Way hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Water Way" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The smarter way to manage water." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Discover professional products for water saving, filtration, irrigation and sustainable living." },
    { "type": "text", "id": "primary_label", "label": "Primary button", "default": "Shop Products" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button", "default": "Explore Categories" }
  ],
  "presets": [{ "name": "Water Way hero" }]
}
{% endschema %}
