<section class="ww-section ww-section--light">
  <div class="ww-container ww-card" style="padding: 2rem;">
    <div class="ww-section__head" style="margin-bottom: 0;">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input aria-label="Email" type="email" name="contact[email]" placeholder="Email address" required style="padding:.85rem 1rem;border:1px solid var(--ww-border);border-radius:999px;min-width:240px;">
        <button class="ww-button" type="submit">Sign up</button>
      {% endform %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get smarter water tips" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Join Water Way for product updates, water-saving ideas and practical guides." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
