<section class="ww-section">
  <div class="ww-container">
    {% assign featured_collection = section.settings.collection %}
    <div class="ww-section__head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>
      {% if featured_collection != blank %}
        <a href="{{ featured_collection.url }}" class="ww-button ww-button--secondary">Shop collection</a>
      {% else %}
        <a href="/collections/all" class="ww-button ww-button--secondary">Shop collection</a>
      {% endif %}
    </div>

    {% if featured_collection != blank and featured_collection.products_count > 0 %}
      <div class="ww-product-grid">
        {% for product in featured_collection.products limit: section.settings.limit %}
          <a class="ww-product-card" href="{{ product.url }}">
            <div class="ww-product-card__image">
              {% if product.featured_image %}
                {% assign image_alt = product.featured_image.alt | default: product.title | escape %}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: image_alt }}
              {% else %}
                <span>Water Way</span>
              {% endif %}
            </div>
            <h3>{{ product.title }}</h3>
            <p class="ww-price">{{ product.price | money }}</p>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="ww-empty">Featured products will appear here after products are imported and assigned to this collection.</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured water solutions" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A curated selection of practical products for saving, filtering and managing water." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 3, "max": 12, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
