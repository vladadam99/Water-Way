<section class="ww-section">
  <div class="ww-container">
    <div class="ww-section__head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>
      <a href="/collections" class="ww-button ww-button--secondary">View all</a>
    </div>
    <div class="ww-grid ww-grid--3">
      <a class="ww-category-card" href="/collections/water-saving"><span>01</span><h3>Water Saving</h3><p>Lower everyday use.</p></a>
      <a class="ww-category-card" href="/collections/water-filtration"><span>02</span><h3>Filtration</h3><p>Improve daily quality.</p></a>
      <a class="ww-category-card" href="/collections/irrigation"><span>03</span><h3>Irrigation</h3><p>Support gardens and greenhouses.</p></a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured categories",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Browse practical Water Way categories." }
  ],
  "presets": [{ "name": "Featured categories" }]
}
{% endschema %}
