<section class="ww-section ww-section--light">
  <div class="ww-container">
    <div class="ww-section__head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>
    </div>
    <div class="ww-trust-bar">
      <div class="ww-trust-item"><strong>Premium Quality Products</strong><br><span>Curated water solutions for daily use.</span></div>
      <div class="ww-trust-item"><strong>Fast UK Dispatch</strong><br><span>Built around UK homes, gardens and businesses.</span></div>
      <div class="ww-trust-item"><strong>Expert Support</strong><br><span>Clear advice before and after purchase.</span></div>
      <div class="ww-trust-item"><strong>Secure Payments</strong><br><span>A clean buying experience from basket to checkout.</span></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust bar",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why choose Water Way?" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Premium water solutions that help customers save water, improve water quality and care for homes, gardens and businesses." }
  ],
  "presets": [{ "name": "Trust bar" }]
}
{% endschema %}
