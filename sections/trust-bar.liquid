<section class="ww-section ww-section--light">
  <div class="ww-container">
    <div class="ww-section__head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>
    </div>
    <div class="ww-trust-bar">
      <div class="ww-trust-item"><strong>Quality first</strong><br><span>Curated products for real water problems.</span></div>
      <div class="ww-trust-item"><strong>UK focused</strong><br><span>Built around UK homes, gardens and businesses.</span></div>
      <div class="ww-trust-item"><strong>Expert guidance</strong><br><span>Clear advice before and after purchase.</span></div>
      <div class="ww-trust-item"><strong>Water efficiency</strong><br><span>Practical upgrades that make every drop count.</span></div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Trust bar",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why choose Water Way?" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "We focus on practical water products that help customers save, filter, irrigate, clean and protect." }
  ],
  "presets": [{ "name": "Trust bar" }]
}
{% endschema %}
